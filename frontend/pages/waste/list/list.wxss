/* 
 * Waste List Page Styles
 * Font sizes optimized for better readability (Dec 2024)
 * - Waste names: 36rpx (was 30rpx)
 * - Waste codes: 28rpx (was 20rpx) 
 * - Detail labels/values: 28rpx (was 24rpx)
 * - Storage info: 20rpx/26rpx (was 16rpx/22rpx)
 */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-top: 0;
  display: flex;
  flex-direction: column;
}

/* Make search bar truly full width */
.search-container {
  margin: 16px 8px 20px;
  padding: 0;
  background: transparent;
  border: none;
  width: calc(100% - 16px);
}

.search-bar {
  display: flex;
  align-items: center;
  width: 100%;
  max-width: none;
  background: #ffffff;
  border: 2px solid #e2e8f0;
  border-radius: 25px;
  padding: 14px 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  position: relative;
  box-sizing: border-box;
}

.search-bar:focus-within {
  border-color: #6366f1;
  background: #fefefe;
  box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
  transform: translateY(-1px);
}

.search-icon {
  margin-right: 12px;
  color: #9ca3af;
  font-size: 16px;
}

.search-input {
  flex: 1;
  font-size: 15px;
  color: #374151;
  background: transparent;
  border: none;
  outline: none;
}

.search-input::placeholder {
  color: #9ca3af;
  font-size: 15px;
  font-weight: 400;
}

/* Fix waste list layout to eliminate bottom white space */
.waste-list {
  flex: 1;
  padding: 0 20px;
  margin-top: 0;
  margin-bottom: 0;
  padding-bottom: 10px;
  overflow-y: auto;
}

.waste-item {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 1rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.waste-item:last-child {
  margin-bottom: 0;
}

.waste-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12);
}

.waste-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.title-section {
  flex: 1;
  margin-right: 20rpx;
}

.waste-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.waste-code {
  background: #f5f7fa;
  color: #5a6c7d;
  font-size: 28rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
  display: inline-block;
}

.storage-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 18rpx;
  border-radius: 12rpx;
  min-width: 130rpx;
  box-shadow: 0 3rpx 8rpx rgba(0,0,0,0.12);
  flex-shrink: 0;
}

.storage-label {
  font-size: 24rpx;
  color: #5f6368;
  margin-bottom: 4rpx;
  font-weight: 600;
  text-align: center;
  white-space: nowrap;
}

.storage-amount {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #1a73e8;
  text-align: center;
  white-space: nowrap;
}

.waste-details {
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.detail-row .label {
  font-size: 28rpx;
  color: #5f6368;
  font-weight: 500;
  width: 140rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.detail-row .value {
  font-size: 28rpx;
  color: #202124;
  flex: 1;
  font-weight: 400;
  line-height: 1.4;
  word-break: break-word;
}

/* Perfect property tags */
.property-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.property-tag {
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.property-tag.flammable {
  background: #fff3e0;
  color: #f57c00;
  border: 1rpx solid #ffcc80;
}

.property-tag.toxic {
  background: #fce4ec;
  color: #c2185b;
  border: 1rpx solid #f8bbd9;
}

.property-tag.corrosive {
  background: #e8f5e8;
  color: #388e3c;
  border: 1rpx solid #a5d6a7;
}

.property-tag.oxidizing {
  background: #e3f2fd;
  color: #1976d2;
  border: 1rpx solid #90caf9;
}

.property-tag.volatile {
  background: #f3e5f5;
  color: #7b1fa2;
  border: 1rpx solid #ce93d8;
}

.property-tag.reactive {
  background: #fff8e1;
  color: #f57f17;
  border: 1rpx solid #fff176;
}

.loading, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 24rpx;
}

/* Mobile responsive - maintain full width concept */
@media (max-width: 768px) {
  .search-container {
    margin: 12px 6px 16px;
    width: calc(100% - 12px);
  }
  
  .search-bar {
    padding: 12px 16px;
  }
  
  .search-input {
    font-size: 14px;
  }
  
  .search-input::placeholder {
    font-size: 14px;
  }
  
  .waste-list {
    padding: 0 12px;
  }
} 