/* Container */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 30rpx 20rpx 20rpx 20rpx;
}

/* Loading State */
.loading-state {
  text-align: center;
  padding: 100rpx 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #6c757d;
}

/* Results Content */
.results-content {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

/* Result Summary */
.result-summary {
  background: white;
  border-radius: 20rpx;
  padding: 35rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.summary-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.result-status {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.result-status.success {
  color: #28a745;
}

.result-status.failed {
  color: #dc3545;
}

.status-icon {
  font-size: 50rpx;
  font-weight: bold;
  margin-right: 15rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
}

.calculation-time {
  font-size: 26rpx;
  color: #6c757d;
}

.result-message {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 15rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
  border-left: 4rpx solid #667eea;
}

.message-text {
  font-size: 28rpx;
  color: #495057;
  line-height: 1.6;
}

/* Key Metrics */
.key-metrics {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180rpx, 1fr));
  gap: 20rpx;
}

.metric-item {
  text-align: center;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 15rpx;
  padding: 25rpx 15rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.metric-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.metric-label {
  display: block;
  font-size: 24rpx;
  color: #6c757d;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.metric-value {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #2c3e50;
}

.metric-value.good {
  color: #28a745;
}

.metric-value.warning {
  color: #ffc107;
}

/* Section Styles */
.indicators-section, .waste-details-section, .constraints-section, .violations-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #f8f9fa;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-right: 15rpx;
}

.section-count {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 15rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* Indicators Grid */
.indicators-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280rpx, 1fr));
  gap: 20rpx;
}

.indicator-item {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 15rpx;
  padding: 25rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.indicator-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
  background: linear-gradient(135deg, #e9ecef 0%, #dee2e6 100%);
}

.indicator-name {
  display: block;
  font-size: 26rpx;
  color: #6c757d;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.indicator-value {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

/* Waste Details */
.waste-details-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.waste-detail-item {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 15rpx;
  padding: 25rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.waste-detail-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.waste-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.waste-code {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.waste-percentage {
  font-size: 26rpx;
  font-weight: bold;
  color: #28a745;
}

.waste-name {
  display: block;
  font-size: 26rpx;
  color: #495057;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.waste-metrics {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120rpx, 1fr));
  gap: 15rpx;
}

.metric {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.metric-label {
  font-size: 22rpx;
  color: #6c757d;
  margin-bottom: 5rpx;
}

.metric-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #2c3e50;
}

/* Constraints */
.constraints-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.constraint-item {
  border-radius: 15rpx;
  padding: 25rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.constraint-item.passed {
  background: linear-gradient(135deg, rgba(40, 167, 69, 0.05) 0%, rgba(40, 167, 69, 0.1) 100%);
  border-color: rgba(40, 167, 69, 0.2);
}

.constraint-item.failed {
  background: linear-gradient(135deg, rgba(220, 53, 69, 0.05) 0%, rgba(220, 53, 69, 0.1) 100%);
  border-color: rgba(220, 53, 69, 0.2);
}

.constraint-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.constraint-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.constraint-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
}

.constraint-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.constraint-status.passed {
  color: #28a745;
}

.constraint-status.failed {
  color: #dc3545;
}

.constraint-values {
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.value-item {
  font-size: 24rpx;
  color: #495057;
  background: rgba(0, 0, 0, 0.05);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.constraint-desc {
  font-size: 22rpx;
  color: #6c757d;
  font-style: italic;
  line-height: 1.5;
}

/* Success and Failure Result Containers */
.success-results, .failure-results {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

/* Enhanced Result Summary */
.result-summary.success {
  background: linear-gradient(135deg, rgba(40, 167, 69, 0.05) 0%, rgba(40, 167, 69, 0.1) 100%);
  border: 2rpx solid rgba(40, 167, 69, 0.2);
}

.result-summary.failed {
  background: linear-gradient(135deg, rgba(244, 67, 54, 0.05) 0%, rgba(244, 67, 54, 0.1) 100%);
  border: 2rpx solid rgba(244, 67, 54, 0.2);
}

.result-message.failed {
  background: linear-gradient(135deg, rgba(244, 67, 54, 0.08) 0%, rgba(244, 67, 54, 0.12) 100%);
  border-left: 4rpx solid #dc3545;
}

/* Failure Analysis Section */
.failure-analysis-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(244, 67, 54, 0.1);
}

.section-subtitle {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.6);
  margin-top: 8rpx;
  display: block;
}

.failure-category {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 15rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(244, 67, 54, 0.1);
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid rgba(244, 67, 54, 0.1);
}

.category-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #d32f2f;
}

.category-count {
  background: #d32f2f;
  color: white;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.stock-issues,
.compatibility-issues,
.parameter-issues {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.stock-issue-item,
.parameter-issue-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  background: rgba(244, 67, 54, 0.05);
  border-radius: 12rpx;
  gap: 10rpx;
  border-left: 4rpx solid #d32f2f;
}

.issue-desc,
.parameter-values {
  font-size: 24rpx;
  color: #666;
}

.parameter-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #d32f2f;
}

.issue-item {
  font-size: 26rpx;
  color: #d32f2f;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

/* Violations */
.violations-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.violation-item {
  background: rgba(220, 53, 69, 0.08);
  padding: 18rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #dc3545;
  margin-bottom: 12rpx;
}

.violation-text {
  font-size: 26rpx;
  color: #721c24;
  line-height: 1.5;
  display: block;
}

/* Action Section */
.action-section {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
  margin-top: 20rpx;
}

.action-btn {
  padding: 20rpx 50rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  border: none;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.return-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.return-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
}

/* Empty State */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 140rpx;
  height: 140rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  display: block;
  font-size: 36rpx;
  color: #6c757d;
  margin-bottom: 15rpx;
  font-weight: 600;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #adb5bd;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.empty-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  border: none;
  font-weight: 600;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.3);
}

/* Responsive */
@media screen and (max-width: 750rpx) {
  .indicators-grid {
    grid-template-columns: 1fr;
  }
  
  .key-metrics {
    grid-template-columns: 1fr;
  }
  
  .waste-metrics {
    grid-template-columns: 1fr;
    gap: 10rpx;
  }
  
  .constraint-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 10rpx;
  }
  
  .constraint-values {
    flex-direction: column;
    gap: 10rpx;
  }
}

/* Indicators Table */
.indicators-table {
  width: 100%;
  border-radius: 15rpx;
  overflow: hidden;
  background: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #e9ecef;
}

.table-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  padding: 0;
}

.header-cell {
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  padding: 20rpx 15rpx;
  text-align: center;
  border-right: 1rpx solid rgba(255, 255, 255, 0.2);
}

.header-cell:last-child {
  border-right: none;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #f1f3f4;
  transition: all 0.2s ease;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row:hover {
  background: #f8f9fa;
}

.table-cell {
  padding: 20rpx 15rpx;
  font-size: 24rpx;
  text-align: center;
  border-right: 1rpx solid #e9ecef;
  display: flex;
  align-items: center;
  justify-content: center;
}

.table-cell:last-child {
  border-right: none;
}

.parameter-col {
  flex: 2;
  text-align: left;
  font-weight: 500;
  color: #2c3e50;
}

.target-col {
  flex: 2;
  color: #495057;
  font-size: 22rpx;
}

.actual-col {
  flex: 2;
  font-weight: bold;
  font-size: 22rpx;
}

.status-col {
  flex: 1;
  font-size: 28rpx;
}

.actual-col.passed {
  color: #28a745;
}

.actual-col.failed {
  color: #dc3545;
}

.actual-col.no-data {
  color: #6c757d;
  font-style: italic;
}

.status-passed {
  color: #28a745;
}

.status-failed {
  color: #dc3545;
}

/* Responsive table */
@media screen and (max-width: 750rpx) {
  .table-header,
  .table-row {
    flex-direction: column;
  }
  
  .header-cell,
  .table-cell {
    border-right: none;
    border-bottom: 1rpx solid #e9ecef;
    text-align: left;
    padding: 15rpx 20rpx;
  }
  
  .parameter-col,
  .target-col,
  .actual-col,
  .status-col {
    flex: 1;
  }
  
  .header-cell:before,
  .table-cell:before {
    content: attr(data-label) ": ";
    font-weight: bold;
    display: inline-block;
    width: 80rpx;
  }
} 