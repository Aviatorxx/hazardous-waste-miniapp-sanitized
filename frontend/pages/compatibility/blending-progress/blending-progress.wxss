/* pages/compatibility/blending-progress/blending-progress.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
}

/* Main Title */
.main-title-container {
  text-align: center;
  margin-bottom: 60rpx;
  margin-top: 40rpx;
  padding: 0 40rpx;
}

.main-title {
  font-size: 44rpx;
  font-weight: 700;
  color: white;
  display: block;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 2rpx;
}

.main-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  font-weight: 300;
  letter-spacing: 1rpx;
}

/* Progress Section */
.progress-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  max-width: 750rpx;
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
  min-height: 100vh;
}

/* Status Icon */
.status-icon-container {
  margin-bottom: 60rpx;
}

.loading-icon {
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: pulse 2s infinite;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.rotating-icon {
  width: 100rpx;
  height: 100rpx;
  animation: rotate 2s linear infinite;
  filter: brightness(0) invert(1);
}

.success-icon, .failure-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: scaleIn 0.5s ease-out;
}

.success-icon {
  background: rgba(76, 175, 80, 0.2);
  border: 4rpx solid #4CAF50;
}

.failure-icon {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: scaleIn 0.6s ease-out;
  background: rgba(255, 255, 255, 0.08);
  border: 3rpx solid rgba(255, 107, 107, 0.6);
  box-shadow: 0 8rpx 32rpx rgba(244, 67, 54, 0.2);
}

.success-checkmark {
  font-size: 80rpx;
  color: #4CAF50;
  font-weight: bold;
}

.failure-exclamation {
  font-size: 88rpx;
  color: #ff6b6b;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* Status Text */
.status-text-container {
  text-align: center;
  margin-bottom: 50rpx;
  max-width: 600rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 16rpx;
  display: block;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.4;
  display: block;
}

.status-desc.success {
  color: #C8E6C9;
}

.status-desc.failure {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
  display: block;
  font-weight: 400;
}

/* Progress Bar */
.progress-container {
  width: 100%;
  margin-bottom: 40rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  display: block;
}

/* Result Summary */
.result-summary {
  width: 100%;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.result-summary.success {
  border: 2rpx solid rgba(76, 175, 80, 0.3);
}

.result-summary.failure {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 45rpx 40rpx;
  margin-bottom: 50rpx;
  border: 1rpx solid rgba(255, 107, 107, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.summary-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  display: block;
}

.failure-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.failure-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff9999;
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.failure-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  font-weight: 300;
}

/* Key Indicators */
.key-indicators {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.indicator-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
}

.indicator-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.indicator-value {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
}

.auto-redirect-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
  display: block;
}

/* Completion indicator for quick navigation */
.completion-indicator {
  text-align: center;
  margin-top: 20rpx;
}

.completion-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  animation: fadeIn 0.3s ease-in;
}

.failure-message {
  text-align: center;
  padding: 20rpx 0;
}

.failure-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  display: block;
  font-weight: 400;
}

/* Action Section */
.action-section {
  padding: 30rpx 40rpx 40rpx 40rpx;
}

.failure-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  max-width: 500rpx;
  margin: 0 auto;
}

.action-btn {
  height: 96rpx;
  border-radius: 24rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  letter-spacing: 1rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.primary-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.secondary-btn {
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
}

.secondary-btn:active {
  transform: translateY(2rpx);
  background: rgba(255, 255, 255, 0.18);
}

/* Calculation Info */
.calculation-info {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  border-radius: 28rpx;
  padding: 40rpx 35rpx;
  margin: 30rpx 40rpx 40rpx 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.info-title {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 24rpx;
  display: block;
  letter-spacing: 0.5rpx;
}

.info-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.7;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 400;
}

.info-text:last-child {
  margin-bottom: 0;
}

/* Animations */
@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.05);
    opacity: 0.8;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes scaleIn {
  from {
    transform: scale(0);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
} 