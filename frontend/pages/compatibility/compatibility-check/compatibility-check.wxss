/* Compatibility Check Page Styles */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-top: 20rpx;
}

/* Error handling */
.error-section {
  padding: 40rpx 30rpx;
  text-align: center;
}

.error-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  background: white;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
}

.error-icon {
  width: 100rpx;
  height: 100rpx;
  opacity: 0.6;
}

.error-message {
  font-size: 30rpx;
  color: #dc3545;
  text-align: center;
}

/* Loading state */
.loading-section {
  padding: 60rpx 30rpx;
  text-align: center;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  background: white;
  padding: 50rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
}

.loading-icon {
  width: 100rpx;
  height: 100rpx;
}

.loading-text {
  font-size: 30rpx;
  color: #6c757d;
}

/* Session Info */
.session-info {
  margin: 20rpx 30rpx;
  padding: 30rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #6c757d;
  margin-right: 20rpx;
  min-width: 140rpx;
}

.info-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

/* Waste Section */
.waste-section {
  margin: 20rpx 30rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.section-title {
  padding: 25rpx 30rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  background: #f8f9fa;
  border-bottom: 2rpx solid #e9ecef;
}

.waste-list {
  padding: 15rpx;
}

.waste-item {
  padding: 25rpx;
  margin-bottom: 15rpx;
  background: #f8f9fa;
  border-radius: 14rpx;
  border-left: 5rpx solid #667eea;
}

.waste-item:last-child {
  margin-bottom: 0;
}

.waste-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.waste-code {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
  margin-right: 20rpx;
}

.waste-name {
  font-size: 26rpx;
  color: #333;
  margin-left: 16rpx;
}

/* Primary display styling for waste names */
.waste-name.primary {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-left: 0;
}

/* Secondary display styling for waste codes */
.waste-code.secondary {
  font-size: 22rpx;
  color: #6c757d;
  margin-left: 8rpx;
  font-weight: 400;
}

.waste-details {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-text {
  font-size: 24rpx;
  color: #6c757d;
}

/* Check Section */
.check-section {
  margin: 20rpx 30rpx;
}

/* Status States */
.status-idle, .status-checking, .status-completed, .status-failed {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.08);
}

.status-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 30rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.status-icon.checking {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.status-icon.failed {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
}

.icon {
  width: 60rpx;
  height: 60rpx;
}

.rotating {
  animation: rotate 2s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.status-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.status-desc {
  font-size: 26rpx;
  color: #6c757d;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

/* Progress bar */
.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #e9ecef;
  border-radius: 4rpx;
  overflow: hidden;
  margin-top: 30rpx; /* Reduced from 40rpx */
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
  border-radius: 4rpx;
  animation: progress 2s ease-in-out infinite;
}

@keyframes progress {
  0% { width: 0%; }
  50% { width: 70%; }
  100% { width: 100%; }
}

/* Results Summary - Optimized for compact layout */
.results-summary {
  background: #f8f9fa;
  border-radius: 18rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.summary-header {
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
}

.result-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 25rpx;
}

.result-icon.success {
  background: #d4edda;
  border: 3rpx solid #28a745;
}

.result-icon.danger {
  background: #f8d7da;
  border: 3rpx solid #dc3545;
}

.result-symbol {
  font-size: 32rpx;
  font-weight: 600;
}

.result-icon.success .result-symbol {
  color: #28a745;
}

.result-icon.danger .result-symbol {
  color: #dc3545;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.summary-stats {
  display: flex;
  gap: 30rpx;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-number {
  display: block;
  font-size: 42rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #6c757d;
}

/* Compatibility status text */
.compatibility-status {
  margin-top: 25rpx;
}

/* Debug information styles */
.debug-section {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border: 2rpx dashed #6c757d;
  border-radius: 10rpx;
}

.debug-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #495057;
  display: block;
  margin-bottom: 15rpx;
}

.debug-text {
  font-size: 24rpx;
  color: #6c757d;
  display: block;
  margin-bottom: 8rpx;
  font-family: monospace;
}

.debug-info {
  margin-top: 10rpx;
  padding: 10rpx;
  background: #e9ecef;
  border-radius: 5rpx;
  font-size: 22rpx;
}

.status-text {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  display: block;
}

.status-text.success {
  color: #155724;
  background: #d4edda;
  padding: 20rpx;
  border-radius: 10rpx;
  border: 2rpx solid #c3e6cb;
}

.status-text.danger {
  color: #721c24;
  background: #f8d7da;
  padding: 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid #f5c6cb;
}

/* Incompatible Section - Optimized spacing */
.incompatible-section {
  margin: 20rpx 30rpx; /* Reduced from 40rpx */
  background: white;
  border-radius: 20rpx; /* Reduced from 24rpx */
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08); /* Lighter shadow */
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 25rpx; /* Reduced from 30rpx */
}

.section-title {
  font-size: 30rpx; /* Reduced from 32rpx */
  font-weight: 600;
  color: #333;
  background: none;
  padding: 0;
  border: none;
}

.section-count {
  background: #dc3545;
  color: white;
  padding: 6rpx 14rpx; /* Reduced from 8rpx 16rpx */
  border-radius: 18rpx; /* Reduced from 20rpx */
  font-size: 22rpx; /* Reduced from 24rpx */
  font-weight: 600;
}

.incompatible-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx; /* Reduced from 24rpx */
}

.incompatible-item {
  padding: 25rpx; /* Reduced from 30rpx */
  margin-bottom: 15rpx; /* Reduced from 20rpx */
  background: #fff5f5;
  border-radius: 14rpx; /* Reduced from 16rpx */
  border-left: 5rpx solid #dc3545; /* Reduced from 6rpx */
}

.incompatible-item:last-child {
  margin-bottom: 0;
}

.pair-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx; /* Reduced from 20rpx */
}

.vs-text {
  font-size: 26rpx; /* Reduced from 28rpx */
  color: #dc3545;
  font-weight: 600;
  margin: 0 18rpx; /* Reduced from 20rpx */
}

.risk-info {
  margin-top: 14rpx; /* Reduced from 16rpx */
}

.risk-codes {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx; /* Reduced from 12rpx */
  margin-bottom: 14rpx; /* Reduced from 16rpx */
}

.risk-code {
  background: #dc3545;
  color: white;
  padding: 6rpx 14rpx; /* Reduced from 8rpx 16rpx */
  border-radius: 18rpx; /* Reduced from 20rpx */
  font-size: 18rpx; /* Reduced from 20rpx */
  font-weight: 600;
}

.risk-desc {
  font-size: 24rpx; /* Reduced from 26rpx */
  color: #721c24;
  line-height: 1.5;
}

/* Risk Section - Optimized spacing */
.risk-section {
  background: #fff8e1;
  border-radius: 18rpx; /* Reduced from 20rpx */
  padding: 30rpx; /* Reduced from 40rpx */
  margin-bottom: 20rpx; /* Reduced from 40rpx */
  border: 2rpx solid #ffecb3;
}

.risk-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx; /* Reduced from 16rpx */
}

.risk-factor {
  font-size: 26rpx; /* Reduced from 28rpx */
  color: #e65100;
  background: white;
  padding: 18rpx; /* Reduced from 20rpx */
  border-radius: 10rpx; /* Reduced from 12rpx */
  border-left: 3rpx solid #ff9800; /* Reduced from 4rpx */
}

/* Action buttons - Optimized spacing */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx; /* Reduced from 24rpx */
  margin-top: 40rpx; /* Reduced from 60rpx */
}

.action-btn {
  width: 100%;
  height: 76rpx; /* Reduced from 80rpx */
  border-radius: 14rpx; /* Reduced from 16rpx */
  font-size: 30rpx; /* Reduced from 32rpx */
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.action-btn:disabled {
  background: #e9ecef !important;
  color: #6c757d !important;
  opacity: 0.6;
}

.start-btn, .continue-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.restart-btn, .retry-btn {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
}

.secondary-btn {
  background: #f8f9fa;
  color: #6c757d;
  border: 2rpx solid #dee2e6;
}

.action-btn:active:not(:disabled) {
  transform: scale(0.98);
}

/* Failed state improvements */
.failed-details {
  margin: 30rpx 0;
  padding: 30rpx;
  background: #f8d7da;
  border-radius: 16rpx;
  border: 2rpx solid #f5c6cb;
}

.error-detail {
  font-size: 28rpx;
  color: #721c24;
  text-align: center;
  line-height: 1.5;
}

.failed-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

/* Recommendations - Optimized spacing */
.recommendations {
  margin: 20rpx 30rpx; /* Reduced from 40rpx */
  padding: 30rpx; /* Reduced from 40rpx */
  background: #fff3cd;
  border-radius: 20rpx; /* Reduced from 24rpx */
  border-left: 6rpx solid #ffc107; /* Reduced from 8rpx */
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08); /* Lighter shadow */
}

.recommendation-list {
  margin-top: 18rpx; /* Reduced from 20rpx */
}

.recommendation-item {
  display: block;
  font-size: 26rpx; /* Reduced from 28rpx */
  color: #856404;
  margin-bottom: 16rpx;
  line-height: 1.6;
  background: white;
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #ffc107;
}

/* Incompatible Warning Styles */
.incompatible-warning {
  display: flex;
  align-items: flex-start;
  background: #fff3cd;
  border: 2rpx solid #ffeaa7;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.warning-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.warning-content {
  flex: 1;
}

.warning-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #856404;
  margin-bottom: 12rpx;
}

.warning-desc {
  display: block;
  font-size: 26rpx;
  color: #856404;
  line-height: 1.5;
}

/* Improved waste info display */
.waste-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.waste-name {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

/* Conflict reason styling */
.conflict-reason {
  margin-bottom: 16rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border-left: 4rpx solid #dc3545;
}

.reason-label {
  font-size: 24rpx;
  color: #6c757d;
  margin-right: 8rpx;
}

.reason-text {
  font-size: 26rpx;
  color: #721c24;
  font-weight: 500;
}

.risk-label {
  font-size: 24rpx;
  color: #6c757d;
  margin-right: 12rpx;
}

/* Compatible pairs styling */
.compatible-section {
  margin: 40rpx;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.compatible-item {
  padding: 30rpx;
  margin-bottom: 20rpx;
  background: #f0f8f0;
  border-radius: 16rpx;
  border-left: 6rpx solid #28a745;
}

.compatible-item:last-child {
  margin-bottom: 0;
}

.compatibility-info {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: rgba(40, 167, 69, 0.1);
  border-radius: 12rpx;
}

.compatibility-text {
  font-size: 26rpx;
  color: #28a745;
  font-weight: 500;
}