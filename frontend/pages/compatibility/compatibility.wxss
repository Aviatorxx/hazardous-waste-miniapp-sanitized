.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 20rpx;
}



.function-buttons {
  margin-bottom: 20rpx;
}

/* Amount Constraint Notice */
.constraint-notice {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(147, 197, 253, 0.05));
  border: 2rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin: 0 0 30rpx 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.constraint-icon {
  font-size: 32rpx;
  color: #3b82f6;
}

.constraint-text {
  font-size: 28rpx;
  color: #1e40af;
  font-weight: 500;
  flex: 1;
}

.button-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.function-btn {
  flex: 1;
  height: 160rpx;
  background: white;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.function-btn:not(.disabled):active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
}

.function-btn.disabled {
  opacity: 0.6;
  background: #f8f9fa;
}

.function-btn.import-btn:not(.disabled) {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.function-btn.compatibility-btn:not(.disabled) {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.function-btn.blending-btn:not(.disabled) {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
}

.function-btn.view-btn:not(.disabled) {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  color: white;
}

.btn-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 10rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.btn-desc {
  font-size: 24rpx;
  opacity: 0.8;
}

.loading-indicator {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
}

.loading-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* Status indicators for blending button */
.status-indicator {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.status-indicator.success {
  background: #4CAF50;
  color: white;
}

.status-indicator.failure {
  background: #F44336;
  color: white;
}

.waste-section {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f8f9fa;
}

.section-title {
  display: flex;
  align-items: center;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-right: 10rpx;
}

.count-badge {
  background: #667eea;
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.section-actions {
  display: flex;
  gap: 10rpx;
}

.reset-btn {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: white;
  border: none;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.3);
  transition: all 0.3s ease;
}

.reset-btn:active {
  transform: scale(0.96);
  box-shadow: 0 1rpx 4rpx rgba(99, 102, 241, 0.4);
}

/* Reset button styling moved to above */

.empty-state {
  text-align: center;
  padding: 80rpx 20rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #6c757d;
  margin-bottom: 10rpx;
}

.empty-desc {
  display: block;
  font-size: 28rpx;
  color: #adb5bd;
}

.waste-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.waste-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #fafbfc;
  border-radius: 16rpx;
  margin-bottom: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  position: relative;
}

.waste-info {
  flex: 1;
  margin-right: 16rpx;
  min-width: 0;
}

.waste-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
  gap: 12rpx;
  min-height: 48rpx;
}

.waste-code {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
  flex-shrink: 0;
  align-self: flex-start;
}

.source-unit {
  color: #6c757d;
  font-size: 24rpx;
  background: #f8f9fa;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
  flex: 1;
  text-align: left;
  line-height: 1.3;
  align-self: flex-start;
  min-height: 32rpx;
  display: flex;
  align-items: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200rpx;
}

.waste-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 18rpx;
  line-height: 1.4;
}

.waste-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 4rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  min-height: 36rpx;
  line-height: 1.3;
}

.label {
  color: #6c757d;
  margin-right: 12rpx;
  min-width: 120rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.value {
  font-weight: 600;
  color: #2c3e50;
  flex: 1;
  text-align: left;
}

.value.set {
  color: #28a745;
  font-weight: 700;
}

.value.unset {
  color: #dc3545;
  font-style: italic;
  font-weight: 500;
}

.waste-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 100rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 10rpx 18rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  min-width: 80rpx;
  font-weight: 600;
}

.delete-btn {
  background: #dc3545;
  color: white;
  width: 100rpx;
}

.summary-info {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f8f9fa;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.summary-item {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 180rpx;
  padding: 12rpx 0;
}

.summary-label {
  font-size: 26rpx;
  color: #6c757d;
  margin-right: 10rpx;
}

.summary-value {
  font-size: 26rpx;
  font-weight: bold;
  color: #2c3e50;
}

.summary-value.status-draft {
  color: #6c757d;
}

.summary-value.status-compatible {
  color: #28a745;
}

.summary-value.status-incompatible {
  color: #dc3545;
}

.summary-value.status-calculation_success {
  color: #28a745;
}

.summary-value.status-calculation_failed {
  color: #dc3545;
}

/* Bottom Action Area */
.action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.1);
  border-top: 1rpx solid #e5e5e5;
  z-index: 1000;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-button {
  flex: 1;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.action-button.compatibility-btn {
  background: #10b981;
  color: white;
}

.action-button.blending-btn {
  background: #6366f1;
  color: white;
}

.action-button.compatibility-btn[disabled],
.action-button.blending-btn[disabled] {
  background: #d1d5db;
  color: #9ca3af;
}

.action-button:not([disabled]):active {
  transform: scale(0.98);
}

/* Add padding to bottom of container to account for fixed action area */
.container {
  padding-bottom: 120rpx;
}

/* Amount Status Indicators */
.summary-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.summary-value text {
  display: inline;
}

/* Status-specific colors for amount display */
.summary-value.amount-insufficient {
  color: #dc3545;
}

.summary-value.amount-normal {
  color: #28a745;
}

.summary-value.amount-excessive {
  color: #fd7e14;
}

/* Enhanced Blending Button with Amount Status */
.function-btn.blending-btn.amount-warning:not(.disabled) {
  background: linear-gradient(135deg, rgba(79, 172, 254, 0.7) 0%, rgba(0, 242, 254, 0.7) 100%);
  opacity: 0.6;
  position: relative;
}

.function-btn.blending-btn.amount-warning:not(.disabled)::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 193, 7, 0.1);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 193, 7, 0.3);
}

.function-btn.blending-btn.amount-optimal:not(.disabled) {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  box-shadow: 0 4rpx 20rpx rgba(79, 172, 254, 0.3);
}

/* Amount status indicators on blending button */
.amount-warning-indicator {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 193, 7, 0.9);
  border-radius: 50%;
  z-index: 10;
}

.amount-success-indicator {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(40, 167, 69, 0.9);
  border-radius: 50%;
  z-index: 10;
}

.warning-icon,
.success-icon {
  font-size: 20rpx;
  color: white;
  font-weight: bold;
}

/* Enhanced Summary Section */
.summary-info-enhanced {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f8f9fa;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.summary-card {
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.amount-card {
  border-left: 6rpx solid #667eea;
}

.heat-card {
  border-left: 6rpx solid #f093fb;
}

.summary-main-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.summary-card .summary-label {
  font-size: 24rpx;
  color: #6c757d;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.summary-card .summary-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  line-height: 1.2;
}

.summary-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.status-icon {
  font-size: 20rpx;
}

.status-text {
  font-size: 22rpx;
  font-weight: 600;
}

.status-text.amount-insufficient {
  color: #dc3545;
}

.status-text.amount-normal {
  color: #28a745;
}

.status-text.amount-excessive {
  color: #fd7e14;
}

.summary-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  opacity: 0.3;
}

.heat-icon {
  font-size: 32rpx;
}

.compatibility-status-card {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 16rpx;
}

.compatibility-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.compatibility-label {
  font-size: 28rpx;
  color: #6c757d;
  font-weight: 600;
}

.compatibility-value {
  font-size: 28rpx;
  font-weight: bold;
}

.compatibility-value.status-compatible,
.compatibility-value.status-calculation_success {
  color: #28a745;
}

.compatibility-value.status-incompatible,
.compatibility-value.status-calculation_failed {
  color: #dc3545;
}

.compatibility-value.status-draft,
.compatibility-value.status-waste_selected {
  color: #6c757d;
}

.compatibility-value.status-compatibility_checking,
.compatibility-value.status-calculating {
  color: #fd7e14;
}

.summary-details {
  background: rgba(102, 126, 234, 0.05);
  border-radius: 12rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.detail-text {
  font-size: 24rpx;
  color: #6c757d;
  text-align: center;
  display: block;
}

/* Responsive adjustments */
@media screen and (max-width: 750rpx) {
  .button-row {
    flex-direction: column;
  }
  
  .function-btn {
    height: 120rpx;
  }
  
  .waste-item {
    flex-direction: column;
    gap: 15rpx;
  }
  
  .waste-actions {
    flex-direction: row;
    justify-content: flex-end;
  }
  
  .summary-info {
    flex-direction: column;
  }
  
  .summary-grid {
    grid-template-columns: 1fr;
    gap: 12rpx;
  }
  
  .summary-card {
    padding: 16rpx;
  }
  
  .summary-card .summary-label {
    font-size: 22rpx;
  }
  
  .summary-card .summary-value {
    font-size: 26rpx;
  }
  
  .compatibility-label,
  .compatibility-value {
    font-size: 26rpx;
  }
} 