.image-viewer-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  margin: 40rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.full-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.image-details {
  margin-bottom: 30rpx;
}

.detail-item {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.close-btn {
  width: 100%;
  padding: 20rpx;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}