  margin-bottom: 12px;
  padding: 8px 12px;
  background: rgba(220, 38, 38, 0.1);
  border-radius: 6px;
  border-left: 4px solid #dc2626;
}

.hazard-icon {
  font-size: 20px;
  margin-right: 8px;
}

.hazard-text {
  flex: 1;
  font-size: 14px;
  font-weight: 600;
  color: #dc2626;
}

.hazard-badge {
  background: #dc2626;
  color: white;
  padding: 4px 8px;
  border-radius: 12px;
  font-size: 10px;
  font-weight: 600;
}

/* Hazard-specific badge colors */
.hazard_oxidizing-badge { background: #dc2626; }
.hazard_reducing-badge { background: #2563eb; }
.hazard_volatile-badge { background: #6b7280; }
.hazard_flammable-badge { background: #ea580c; }
.hazard_toxic-badge { background: #7c3aed; }
.hazard_reactive-badge { background: #059669; }
.hazard_infectious-badge { background: #dc2626; }
.hazard_corrosive-badge { background: #ca8a04; }
.hazard_halogenated-badge { background: #0891b2; }
.hazard_cyanide-badge { background: #1f2937; }

.hazard-elements {
